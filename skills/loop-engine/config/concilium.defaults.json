{
  "version": 1,
  "product_name": "Concilium",
  "lanes": {
    "fast": {
      "default_single_agent": "kimi",
      "verify_required": true
    },
    "review": {
      "default_review_executor": "kimi",
      "default_review_reviewer": "hermes",
      "review_repair_limit": 1
    },
    "audit": {
      "default_reviewer": "claude",
      "seats": ["claude", "hermes", "kimi"],
      "allowed_report_paths": ["docs/audits/*.md"]
    },
    "plan_review": {
      "seats": ["claude", "hermes", "kimi"],
      "max_rounds": 3
    },
    "roundtable": {
      "commander": "claude",
      "reviewer": "",
      "seats": ["claude", "hermes", "kimi"]
    }
  },
  "routing": {
    "risk_posture": "balanced",
    "allow_auto_escalation": true,
    "allow_auto_downgrade": false
  },
  "capacity": {
    "warn_below_percent": 20,
    "block_below_percent": 5,
    "max_status_age_seconds": 300
  },
  "timeouts": {
    "seat_mode_seconds": {
      "claude": {
        "plan": 600,
        "review": 600
      },
      "codex": {
        "plan": 600,
        "review": 600
      }
    }
  },
  "memory": {
    "private_context_dirs": [],
    "private_context_max_file_bytes": 20000,
    "private_context_max_total_bytes": 200000,
    "private_archive_dir": ""
  },
  "privacy": {
    "redact_account_identifiers": true,
    "redact_credentials": true
  }
}
