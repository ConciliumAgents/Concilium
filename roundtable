#!/usr/bin/env bash
# roundtable — Concilium one-shot launcher
#   用法: roundtable --task "<任务>" [--repo <仓库,默认当前目录>] [--test-cmd "<测试命令>"]
#        roundtable service [--port N] [--open|--no-open] [--token-file PATH]
#        roundtable legacy --task "<任务>" [legacy conductor/TUI options]
#   先探座位: roundtable --doctor
#   查看入口版本: roundtable --version
set -euo pipefail

# --- 解析自身真实位置（支持被软链接到 PATH）---
original_src="${BASH_SOURCE[0]}"
src="$original_src"
while [ -h "$src" ]; do
  dir="$(cd -P "$(dirname "$src")" && pwd)"
  src="$(readlink "$src")"
  case "$src" in /*) ;; *) src="$dir/$src";; esac
done
src_dir="$(cd -P "$(dirname "$src")" && pwd)"
src="${src_dir}/$(basename "$src")"
PROJ="$src_dir"
SKILL="$PROJ/skills/loop-engine"
VENV_PY="$PROJ/.venv/bin/python"

usage() { sed -n '2,7p' "$src" | sed 's/^# \{0,1\}//'; }

print_launcher_info() {
  echo "Concilium roundtable"
  echo "entrypoint: ${src}"
  if [ -L "${original_src}" ]; then
    echo "symlink_entrypoint: ${original_src}"
    echo "symlink_target: $(readlink "${original_src}")"
  fi
  echo "repo_root: ${PROJ}"
  git -C "${PROJ}" rev-parse --abbrev-ref HEAD 2>/dev/null | sed 's/^/branch: /' || true
  git -C "${PROJ}" rev-parse --short HEAD 2>/dev/null | sed 's/^/commit: /' || true
  git -C "${PROJ}" status --short 2>/dev/null | sed 's/^/status: /' || true
}

run_legacy() {
  echo "[roundtable] legacy mode is deprecated; use the default Concilium runtime unless you are explicitly testing old conductor/TUI behavior." >&2
  LEGACY_VENV_PY="${CONCILIUM_LEGACY_VENV_PY:-$VENV_PY}"
  if [ -x "$LEGACY_VENV_PY" ] && "$LEGACY_VENV_PY" -c 'import rich' >/dev/null 2>&1; then
    exec "$LEGACY_VENV_PY" "$SKILL/tui/tui.py" ${ARGS[@]+"${ARGS[@]}"}
  else
    LEGACY_PY="${CONCILIUM_LEGACY_PYTHON:-python3}"
    echo "[roundtable] 未找到 .venv+rich，退回纯文本 legacy conductor" >&2
    exec "$LEGACY_PY" "$SKILL/bin/conductor.py" ${ARGS[@]+"${ARGS[@]}"}
  fi
}

# 无参数 / 求助
if [ "$#" -eq 0 ]; then usage; exit 0; fi
case "${1:-}" in -h|--help) usage; exit 0;; esac

# service：启动本地 Concilium API；浏览器 Debug Console 仅作调试，不是 Phase 5 产品 UI。
if [ "${1:-}" = "service" ] || [ "${1:-}" = "serve" ] || [ "${1:-}" = "web" ] || [ "${1:-}" = "--web" ]; then
  cmd="${1:-}"
  shift
  if [ "$cmd" = "web" ] || [ "$cmd" = "--web" ]; then
    echo "[roundtable] 'web' is deprecated; use 'service' for the local Concilium API / Debug Console." >&2
  fi
  PY="${CONCILIUM_LAUNCHER_PYTHON:-python3}"
  exec "$PY" "$SKILL/web/server.py" ${@+"$@"}
fi

if [ "${1:-}" = "sessions" ]; then
  shift
  exec "${CONCILIUM_LAUNCHER_PYTHON:-python3}" "$SKILL/bin/session_retention.py" "$@"
fi

# --version：只看入口版本/路径，不开会
if [ "${1:-}" = "--version" ]; then
  print_launcher_info
  exit 0
fi

# --doctor：入口诊断写 stderr；stdout 保留座位探测输出
if [ "${1:-}" = "--doctor" ]; then
  print_launcher_info >&2
  exec python3 "$SKILL/bin/roster-detect.py"
fi

# 若用户没给 --repo，则默认用当前目录
inject_repo=true
for a in ${@+"$@"}; do
  case "$a" in --repo|--repo=*) inject_repo=false;; esac
done
ARGS=()
$inject_repo && ARGS+=(--repo "$PWD")
[ "$#" -gt 0 ] && ARGS+=("$@")

if [ "${1:-}" = "legacy" ] || [ "${1:-}" = "--legacy" ]; then
  shift
  ARGS=()
  $inject_repo && ARGS+=(--repo "$PWD")
  [ "$#" -gt 0 ] && ARGS+=("$@")
  run_legacy
fi

PY="${CONCILIUM_LAUNCHER_PYTHON:-python3}"
exec "$PY" "$SKILL/bin/concilium-run.py" --live ${ARGS[@]+"${ARGS[@]}"}
